<IfModule mod_rewrite.c>
    RewriteEngine On

    # Allow direct access to the public folder if explicitly requested
    RewriteCond %{REQUEST_URI} !^/public/

    # Rewrite all requests to the public directory
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>

# Prevent directory listings
Options -Indexes

# Protect sensitive Laravel configuration and system files
<FilesMatch "^\.env|composer\.json|composer\.lock|package\.json|vite\.config\.js|package-lock\.json|phpunit\.xml|artisan|DESAIN.md|README.md">
    Order allow,deny
    Deny from all
</FilesMatch>
